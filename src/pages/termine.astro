---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import {
  formatDateRange,
  isEvent,
  sortByDateAscending,
} from '../lib/news';

const baseUrl = import.meta.env.BASE_URL || '/';
const withBase = (path = '') => `${baseUrl}${path}`;
const events = sortByDateAscending((await getCollection('news')).filter(isEvent));
const today = new Date();
today.setHours(0, 0, 0, 0);
const initialEntry = events.find((entry) => entry.data.date.getTime() >= today.getTime()) ?? events[0];
const initialDate = initialEntry?.data.date ?? today;
const initialCalendar = {
  year: initialDate.getFullYear(),
  month: initialDate.getMonth(),
  selectedDate: initialDate.toISOString(),
};
const calendarEvents = events.map((entry) => ({
  slug: entry.slug,
  href: withBase(`news/${entry.slug}`),
  title: entry.data.title,
  preview: entry.data.preview ?? '',
  start: entry.data.date.toISOString(),
  end: entry.data.endDate?.toISOString() ?? entry.data.date.toISOString(),
  hasEnd: Boolean(entry.data.endDate),
  dateLabel: formatDateRange(entry.data.date, entry.data.endDate),
  location: entry.data.location ?? '',
  time: entry.data.time ?? 'siehe Ausschreibung',
  people: entry.data.people ?? [],
  display: entry.data.display,
  color: entry.data.color,
  pdfs: entry.data.pdfs ?? {},
}));
---

<BaseLayout title="Termine">
  <section class="content-block-spacious news-page-intro">
    <h1>Termine</h1>
    <p class="lead-text">Kalender, Timeline und Ausschreibungen fuer Lehrgaenge und besondere Trainings findest du gesammelt auf dieser Seite.</p>
    <p>Kurze Informationen erscheinen direkt im Kalender. Je nach Termin oeffnet sich ein Popup oder eine eigene Detailseite mit PDF-Vorschau und Download.</p>
  </section>

  <section class="content-block-spacious">
    <h2>Kalender</h2>

    <div
      class="calendar-app"
      data-calendar
      data-events={JSON.stringify(calendarEvents)}
      data-initial={JSON.stringify(initialCalendar)}
    >
      <article class="calendar-panel">
        <header class="calendar-toolbar">
          <button class="calendar-nav-btn" type="button" data-calendar-prev aria-label="Vorheriger Monat">&lt;</button>

          <div class="calendar-current">
            <div class="calendar-selects">
              <select id="calendar-month-select" data-calendar-month aria-label="Monat auswaehlen"></select>
              <select id="calendar-year-select" data-calendar-year aria-label="Jahr auswaehlen"></select>
            </div>
            <h3 data-calendar-label></h3>
            <p data-calendar-selected></p>
          </div>

          <button class="calendar-nav-btn" type="button" data-calendar-next aria-label="Naechster Monat">&gt;</button>
        </header>

        <div class="calendar-weekdays">
          <span>Mo</span>
          <span>Di</span>
          <span>Mi</span>
          <span>Do</span>
          <span>Fr</span>
          <span>Sa</span>
          <span>So</span>
        </div>

        <div class="calendar-days" data-calendar-days></div>
      </article>

      <aside class="calendar-detail-panel">
        <p class="calendar-detail-kicker">Auswahl</p>
        <h3 data-detail-title></h3>
        <div class="calendar-detail-list" data-detail-list></div>
      </aside>
    </div>
  </section>

  <section class="content-block-spacious">
    <h2>Timeline</h2>
    <div class="horizontal-timeline news-rail">
      {events.map((entry) => (
          <article class:list={['timeline-event', 'news-card', `tone-${entry.data.color}`]}>
            <div class="news-card-tags">
              <span class="event-date">{formatDateRange(entry.data.date, entry.data.endDate)}</span>
              <span class="news-mode-tag">{entry.data.display === 'page' ? 'Seite' : 'Popup'}</span>
            </div>
            <h3>{entry.data.title}</h3>
            {entry.data.location && <p class="event-location">{entry.data.location}</p>}
            <p>{entry.data.preview}</p>
            <div class="timeline-actions">
              {entry.data.display === 'page' ? (
                <a class="read-more-btn" href={withBase(`news/${entry.slug}`)}>Seite oeffnen</a>
              ) : (
                <button
                  class="read-more-btn"
                  type="button"
                  data-modal-trigger
                  data-slug={entry.slug}
                  data-title={entry.data.title}
                  data-date={entry.data.date.toISOString()}
                  data-end-date={entry.data.endDate?.toISOString() ?? ''}
                >
                  Popup oeffnen
                </button>
              )}

              {entry.data.pdfs?.de && (
                <a class="mini-action" href={entry.data.pdfs.de} target="_blank" rel="noopener">PDF DE</a>
              )}
              {entry.data.pdfs?.en && (
                <a class="mini-action" href={entry.data.pdfs.en} target="_blank" rel="noopener">PDF EN</a>
              )}
              {(entry.data.pdfs?.de || entry.data.pdfs?.en) && (
                <a class="mini-action" href={entry.data.pdfs?.de || entry.data.pdfs?.en} target="_blank" rel="noopener">Vorschau</a>
              )}
            </div>
          </article>
      ))}
    </div>
  </section>

  <div id="news-modal" class="modal" aria-hidden="true">
    <div class="modal-backdrop" data-modal-close></div>
    <div class="modal-content">
      <button class="modal-close" type="button" data-modal-close>&times;</button>
      <div class="modal-header">
        <h2 id="modal-title"></h2>
        <span id="modal-date"></span>
      </div>
      <div class="modal-body" id="modal-body">
        <div class="loader">Laden...</div>
      </div>
    </div>
  </div>
</BaseLayout>

<script is:inline define:vars={{ baseUrl }}>
  const modal = document.getElementById('news-modal');
  const modalTitle = document.getElementById('modal-title');
  const modalDate = document.getElementById('modal-date');
  const modalBody = document.getElementById('modal-body');

  function formatModalDate(startDate, endDate) {
    const start = new Date(startDate);
    const end = endDate ? new Date(endDate) : null;

    if (!endDate || Number.isNaN(end?.getTime())) {
      return start.toLocaleDateString('de-DE', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
      });
    }

    const sameMonth = start.getFullYear() === end.getFullYear() && start.getMonth() === end.getMonth();
    if (sameMonth) {
      return `${start.getDate()}.-${end.getDate()}. ${start.toLocaleDateString('de-DE', { month: 'long', year: 'numeric' })}`;
    }

    return `${start.toLocaleDateString('de-DE')} - ${end.toLocaleDateString('de-DE')}`;
  }

  async function openNewsModal(trigger) {
    const slug = trigger.getAttribute('data-slug');
    const title = trigger.getAttribute('data-title');
    const date = trigger.getAttribute('data-date');
    const endDate = trigger.getAttribute('data-end-date');

    if (!slug || !title || !date || !modal || !modalBody || !modalTitle || !modalDate) {
      return;
    }

    modalTitle.textContent = title;
    modalDate.textContent = formatModalDate(date, endDate);
    modalBody.innerHTML = '<div class="loader">Laden...</div>';
    modalBody.classList.remove('content-visible');
    modal.classList.add('show');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';

    try {
      const response = await fetch(`${baseUrl}news/${slug}.json`);
      const news = await response.json();
      const actions = [];

      if (news.pdfs?.de) {
        actions.push(`<a href="${news.pdfs.de}" class="button button-primary" target="_blank" rel="noopener">PDF Deutsch</a>`);
      }

      if (news.pdfs?.en) {
        actions.push(`<a href="${news.pdfs.en}" class="button button-outline" target="_blank" rel="noopener">PDF English</a>`);
      }

      if (news.pdfs?.de || news.pdfs?.en) {
        const previewHref = news.pdfs?.de || news.pdfs?.en;
        actions.push(`<a href="${previewHref}" class="button button-outline" target="_blank" rel="noopener">Vorschau</a>`);
      }

      modalBody.innerHTML = `
        ${news.location ? `<p class="modal-location">${news.location}</p>` : ''}
        ${actions.length > 0 ? `<div class="modal-actions">${actions.join('')}</div>` : ''}
        <div class="prose-lg">${news.content}</div>
      `;
      modalBody.classList.add('content-visible');
    } catch (error) {
      console.error(error);
      modalBody.innerHTML = '<p>Der Inhalt konnte gerade nicht geladen werden.</p>';
      modalBody.classList.add('content-visible');
    }
  }

  function closeNewsModal() {
    if (!modal || !modalBody) {
      return;
    }

    modal.classList.remove('show');
    modal.setAttribute('aria-hidden', 'true');
    modalBody.classList.remove('content-visible');
    document.body.style.overflow = '';
  }

  function escapeHtml(value) {
    return String(value ?? '').replace(/[&<>"']/g, (character) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#039;',
    }[character]));
  }

  function toDateKey(date) {
    return `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}-${String(date.getDate()).padStart(2, '0')}`;
  }

  function initCalendar() {
    const calendar = document.querySelector('[data-calendar]');
    if (!calendar) return;

    const events = JSON.parse(calendar.getAttribute('data-events') || '[]');
    const initial = JSON.parse(calendar.getAttribute('data-initial') || '{}');
    const monthSelect = calendar.querySelector('[data-calendar-month]');
    const yearSelect = calendar.querySelector('[data-calendar-year]');
    const label = calendar.querySelector('[data-calendar-label]');
    const selectedLabel = calendar.querySelector('[data-calendar-selected]');
    const daysContainer = calendar.querySelector('[data-calendar-days]');
    const detailTitle = calendar.querySelector('[data-detail-title]');
    const detailList = calendar.querySelector('[data-detail-list]');

    const monthNames = Array.from({ length: 12 }, (_, month) =>
      new Date(2026, month, 1).toLocaleDateString('de-DE', { month: 'long' }),
    );
    const eventYears = events.flatMap((event) => [
      new Date(event.start).getFullYear(),
      new Date(event.end).getFullYear(),
    ]);
    const currentYear = new Date().getFullYear();
    const minYear = Math.min(...eventYears, currentYear) - 1;
    const maxYear = Math.max(...eventYears, currentYear) + 1;

    let viewYear = Number(initial.year) || new Date().getFullYear();
    let viewMonth = Number.isInteger(initial.month) ? Number(initial.month) : new Date().getMonth();
    let selectedDate = new Date(initial.selectedDate || new Date());

    monthSelect.innerHTML = monthNames
      .map((name, index) => `<option value="${index}">${escapeHtml(name)}</option>`)
      .join('');
    yearSelect.innerHTML = Array.from({ length: maxYear - minYear + 1 }, (_, index) => minYear + index)
      .map((year) => `<option value="${year}">${year}</option>`)
      .join('');

    function eventsForDate(date) {
      return events.filter((event) => {
        const start = new Date(event.start);
        const end = new Date(event.end);
        start.setHours(0, 0, 0, 0);
        end.setHours(23, 59, 59, 999);
        const target = new Date(date);
        target.setHours(12, 0, 0, 0);
        return target >= start && target <= end;
      });
    }

    function renderDetails() {
      const dayEvents = eventsForDate(selectedDate);
      const dateText = selectedDate.toLocaleDateString('de-DE', {
        weekday: 'long',
        day: 'numeric',
        month: 'long',
        year: 'numeric',
      });

      detailTitle.textContent = dateText;
      selectedLabel.textContent = `Ausgewaehlt: ${dateText}`;

      if (dayEvents.length === 0) {
        detailList.innerHTML = '<p class="calendar-empty-state">An diesem Tag ist kein Termin eingetragen.</p>';
        return;
      }

      detailList.innerHTML = dayEvents.map((event) => {
        const pdfButtons = [
          event.pdfs?.de ? `<a href="${event.pdfs.de}" class="mini-action" target="_blank" rel="noopener">PDF DE</a>` : '',
          event.pdfs?.en ? `<a href="${event.pdfs.en}" class="mini-action" target="_blank" rel="noopener">PDF EN</a>` : '',
          event.pdfs?.de || event.pdfs?.en
            ? `<a href="${event.pdfs.de || event.pdfs.en}" class="mini-action" target="_blank" rel="noopener">Vorschau</a>`
            : '',
        ].join('');
        const primaryAction = event.display === 'page'
          ? `<a class="read-more-btn" href="${event.href}">Seite oeffnen</a>`
          : `<button class="read-more-btn" type="button" data-modal-trigger data-slug="${event.slug}" data-title="${escapeHtml(event.title)}" data-date="${event.start}" data-end-date="${event.hasEnd ? event.end : ''}">Details</button>`;

        return `
          <article class="calendar-detail-card tone-${event.color}">
            <span class="event-date">${escapeHtml(event.dateLabel)}</span>
            <h4>${escapeHtml(event.title)}</h4>
            <dl>
              <div><dt>Zeit</dt><dd>${escapeHtml(event.time)}</dd></div>
              <div><dt>Ort</dt><dd>${escapeHtml(event.location || 'wird bekanntgegeben')}</dd></div>
              <div><dt>Personen</dt><dd>${escapeHtml(event.people?.join(', ') || 'WTA Hochburg-Ach')}</dd></div>
            </dl>
            ${event.preview ? `<p>${escapeHtml(event.preview)}</p>` : ''}
            <div class="calendar-card-actions">${primaryAction}${pdfButtons}</div>
          </article>
        `;
      }).join('');
    }

    function renderCalendar() {
      const firstDay = new Date(viewYear, viewMonth, 1);
      const firstWeekday = (firstDay.getDay() + 6) % 7;
      const daysInMonth = new Date(viewYear, viewMonth + 1, 0).getDate();
      const todayKey = toDateKey(new Date());

      monthSelect.value = String(viewMonth);
      yearSelect.value = String(viewYear);
      label.textContent = firstDay.toLocaleDateString('de-DE', { month: 'long', year: 'numeric' });

      const cells = [];

      for (let index = 0; index < firstWeekday; index += 1) {
        cells.push('<div class="calendar-day calendar-day-muted" aria-hidden="true"></div>');
      }

      for (let day = 1; day <= daysInMonth; day += 1) {
        const date = new Date(viewYear, viewMonth, day);
        const dayEvents = eventsForDate(date);
        const bars = dayEvents.slice(0, 4).map((event) => `<span class="event-bar tone-${event.color}"></span>`).join('');
        const hasMore = dayEvents.length > 4 ? `<span class="event-more">+${dayEvents.length - 4}</span>` : '';
        const isSelected = toDateKey(date) === toDateKey(selectedDate);
        const isToday = toDateKey(date) === todayKey;

        cells.push(`
          <button class="calendar-day ${dayEvents.length ? 'calendar-day-active' : ''} ${isSelected ? 'calendar-day-selected' : ''} ${isToday ? 'calendar-day-today' : ''}" type="button" data-date="${date.toISOString()}">
            <span class="calendar-day-number">${day}</span>
            <span class="event-bars">${bars}${hasMore}</span>
          </button>
        `);
      }

      daysContainer.innerHTML = cells.join('');
      renderDetails();
    }

    function setMonth(year, month) {
      viewYear = year;
      viewMonth = month;

      if (viewMonth < 0) {
        viewMonth = 11;
        viewYear -= 1;
      }

      if (viewMonth > 11) {
        viewMonth = 0;
        viewYear += 1;
      }

      selectedDate = new Date(viewYear, viewMonth, Math.min(selectedDate.getDate(), new Date(viewYear, viewMonth + 1, 0).getDate()));
      renderCalendar();
    }

    calendar.querySelector('[data-calendar-prev]')?.addEventListener('click', () => setMonth(viewYear, viewMonth - 1));
    calendar.querySelector('[data-calendar-next]')?.addEventListener('click', () => setMonth(viewYear, viewMonth + 1));
    monthSelect.addEventListener('change', () => setMonth(viewYear, Number(monthSelect.value)));
    yearSelect.addEventListener('change', () => setMonth(Number(yearSelect.value), viewMonth));
    daysContainer.addEventListener('click', (event) => {
      const button = event.target.closest('[data-date]');
      if (!button) return;
      selectedDate = new Date(button.getAttribute('data-date'));
      renderCalendar();
    });
    detailList.addEventListener('click', (event) => {
      const trigger = event.target.closest('[data-modal-trigger]');
      if (trigger) openNewsModal(trigger);
    });

    renderCalendar();
  }

  document.querySelectorAll('[data-modal-trigger]').forEach((trigger) => {
    trigger.addEventListener('click', () => openNewsModal(trigger));
  });

  initCalendar();

  document.querySelectorAll('[data-modal-close]').forEach((closeButton) => {
    closeButton.addEventListener('click', closeNewsModal);
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      closeNewsModal();
    }
  });
</script>

<style>
.news-page-intro {
  padding-bottom: 0;
}

.calendar-app {
  display: grid;
  grid-template-columns: minmax(0, 1.35fr) minmax(320px, 0.65fr);
  gap: 1.25rem;
  align-items: start;
}

.calendar-panel,
.calendar-detail-panel {
  padding: 1.35rem;
  border-radius: 26px;
  background: var(--color-surface);
  border: 1px solid var(--color-border-light);
  box-shadow: var(--shadow-sm);
}

.calendar-detail-panel {
  position: sticky;
  top: 12rem;
}

.calendar-toolbar {
  display: grid;
  grid-template-columns: auto 1fr auto;
  gap: 1rem;
  align-items: center;
  margin-bottom: 1rem;
}

.calendar-current {
  text-align: center;
}

.calendar-current h3 {
  margin: 0.45rem 0 0.2rem;
}

.calendar-current p,
.calendar-detail-kicker {
  margin: 0;
  color: var(--color-text-muted);
  font-size: 0.88rem;
  font-weight: 800;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

.calendar-selects {
  display: flex;
  justify-content: center;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.calendar-selects select,
.calendar-nav-btn {
  border: 1px solid var(--color-border);
  background: var(--color-surface-strong);
  color: var(--color-primary-dark);
  box-shadow: var(--shadow-sm);
}

.calendar-selects select {
  min-height: 2.6rem;
  padding: 0.45rem 0.75rem;
  border-radius: 999px;
  font: inherit;
  font-weight: 800;
}

.calendar-nav-btn {
  width: 3rem;
  height: 3rem;
  border-radius: 50%;
  font-size: 2rem;
  line-height: 1;
  cursor: pointer;
}

.calendar-weekdays,
.calendar-days {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 0.45rem;
}

.calendar-weekdays {
  margin-bottom: 0.6rem;
  color: var(--color-text-muted);
  font-size: 0.82rem;
  font-weight: 800;
  text-align: center;
  text-transform: uppercase;
}

.calendar-day {
  display: grid;
  align-content: space-between;
  min-height: 6.6rem;
  padding: 0.58rem;
  border-radius: 16px;
  background: rgba(54, 88, 66, 0.045);
  border: 1px solid transparent;
  color: var(--color-primary-dark);
  text-align: left;
  cursor: pointer;
}

.calendar-day-muted {
  cursor: default;
  background: transparent;
}

.calendar-day-active {
  background: rgba(49, 86, 62, 0.08);
  border-color: rgba(49, 86, 62, 0.2);
}

.calendar-day-selected {
  outline: 3px solid rgba(188, 162, 112, 0.45);
  background: rgba(188, 162, 112, 0.13);
}

.calendar-day-today .calendar-day-number {
  display: inline-grid;
  place-items: center;
  width: 1.8rem;
  height: 1.8rem;
  border-radius: 50%;
  background: var(--color-primary-dark);
  color: var(--color-surface-strong);
}

.calendar-day-number {
  font-size: 0.9rem;
  font-weight: 900;
}

.event-bars {
  display: grid;
  gap: 0.22rem;
}

.event-bar {
  display: block;
  width: 100%;
  height: 0.34rem;
  border-radius: 999px;
  background: var(--color-primary);
}

.event-more {
  font-size: 0.72rem;
  font-weight: 800;
  color: var(--color-text-muted);
}

.calendar-detail-list {
  display: grid;
  gap: 0.9rem;
  margin-top: 1rem;
}

.calendar-detail-card {
  padding: 1rem;
  border-radius: 18px;
  background: var(--color-surface-strong);
  border: 1px solid var(--color-border-light);
  box-shadow: var(--shadow-sm);
}

.calendar-detail-card h4 {
  margin: 0.8rem 0 0.75rem;
  color: var(--color-primary-dark);
}

.calendar-detail-card dl {
  display: grid;
  gap: 0.5rem;
  margin: 0 0 0.85rem;
}

.calendar-detail-card dl div {
  display: grid;
  grid-template-columns: 5rem minmax(0, 1fr);
  gap: 0.65rem;
}

.calendar-detail-card dt {
  color: var(--color-text-muted);
  font-size: 0.78rem;
  font-weight: 900;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

.calendar-detail-card dd {
  margin: 0;
  color: var(--color-text-secondary);
}

.calendar-detail-card p,
.calendar-empty-state {
  margin: 0;
  color: var(--color-text-secondary);
}

.calendar-card-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.55rem;
  margin-top: 1rem;
}

.mini-action {
  display: inline-flex;
  align-items: center;
  min-height: 2.4rem;
  padding: 0.45rem 0.75rem;
  border-radius: 999px;
  background: rgba(49, 86, 62, 0.08);
  color: var(--color-primary-dark);
  font-size: 0.85rem;
  font-weight: 800;
  text-decoration: none;
}

.news-card-button {
  font: inherit;
  text-align: left;
  border: 1px solid var(--color-border-light);
  background: var(--color-surface);
}

.news-card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  align-items: center;
  margin-bottom: 0.75rem;
}

.news-mode-tag {
  display: inline-flex;
  padding: 0.3rem 0.7rem;
  border-radius: 999px;
  background: rgba(188, 162, 112, 0.15);
  color: var(--color-primary-dark);
  font-size: 0.8rem;
  font-weight: 800;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}

.timeline-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.55rem;
  align-items: center;
  margin-top: 1rem;
}

.event-location {
  font-size: 0.95rem;
  font-weight: 700;
  color: var(--color-text-muted);
}

.modal-location {
  margin-top: 0;
  margin-bottom: 1rem;
  font-size: 0.98rem;
  font-weight: 700;
  color: var(--color-text-muted);
}

.modal-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  margin-bottom: 1.5rem;
}

.timeline-event.tone-moss,
.calendar-detail-card.tone-moss {
  border-left: 4px solid #56704f;
}

.timeline-event.tone-sage,
.calendar-detail-card.tone-sage {
  border-left: 4px solid #90a388;
}

.timeline-event.tone-gold,
.calendar-detail-card.tone-gold {
  border-left: 4px solid #bca270;
}

.event-bar.tone-moss {
  background: #56704f;
}

.event-bar.tone-sage {
  background: #90a388;
}

.event-bar.tone-gold {
  background: #bca270;
}

@media (max-width: 768px) {
  .calendar-app {
    grid-template-columns: 1fr;
