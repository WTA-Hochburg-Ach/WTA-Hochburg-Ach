---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = 'Kontakt';
const pageDescription = 'Kontakt, Trainingszeiten und Ansprechpartner von Wanomichi Takemusu Aikido Hochburg-Ach.';
const googleMapsQuery = 'Athaler Straße 1, 5122 Duttendorf';
const googleMapsEmbed = `https://www.google.com/maps?q=${encodeURIComponent(googleMapsQuery)}&z=15&output=embed`;
const googleMapsLink = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(googleMapsQuery)}`;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="contact-shell">
    <header class="page-header" data-i18n-html="pages.contact.header">
      <h1>Kontakt</h1>
      <p class="lead">Fragen zum Training oder zum Probetraining? Wir freuen uns auf deine Nachricht.</p>
    </header>

    <section class="content-block-spacious">
      <h2 data-i18n="pages.contact.direct_title">Direkter Kontakt</h2>
      <div class="contact-grid">
        <article class="contact-card">
          <div class="contact-icon">✉️</div>
          <div data-i18n-html="pages.contact.card_email">
            <h3>E-Mail</h3>
            <a href="mailto:dojo@aikido-hochburg-ach.at" class="contact-link">dojo@aikido-hochburg-ach.at</a>
          </div>
        </article>

        <article class="contact-card">
          <div class="contact-icon">📱</div>
          <div data-i18n-html="pages.contact.card_phone">
            <h3>Telefon</h3>
            <a href="tel:+436504600020" class="contact-link">+43 650 4600020</a>
          </div>
        </article>

        <article class="contact-card">
          <div class="contact-icon">📍</div>
          <div data-i18n-html="pages.contact.card_location">
            <h3>Trainingsort</h3>
            <p>Mehrzweckhalle der neuen Mittelschule<br />Athaler Straße 1<br />5122 Duttendorf</p>
          </div>
        </article>
      </div>
    </section>

    <section class="content-block-spacious">
      <h2 data-i18n="pages.contact.people_title">Ansprechpartner</h2>
      <div class="contact-grid">
        <article class="contact-card">
          <div data-i18n-html="pages.contact.person_christian">
            <h3>Christian Dostal</h3>
            <p>Obmann</p>
            <a href="tel:+436504600020" class="contact-link">+43 650<br />4600020</a>
            <a href="mailto:dojo@aikido-hochburg-ach.at" class="contact-link">dojo@aikido-hochburg-ach.at</a>
          </div>
        </article>
        <article class="contact-card">
          <div data-i18n-html="pages.contact.person_karin">
            <h3>Karin Sturm</h3>
            <p>Obmannstellvertreterin</p>
            <p class="contact-note">Telefonnummer: +49 xxx</p>
            <a href="mailto:dojo@aikido-hochburg-ach.at" class="contact-link">dojo@aikido-hochburg-ach.at</a>
          </div>
        </article>
        <article class="contact-card">
          <div data-i18n-html="pages.contact.person_sandra">
            <h3>Sandra Šolaja-Pelzer</h3>
            <p>Kassierin</p>
            <p class="contact-note">Telefonnummer: +49 xxx</p>
            <a href="mailto:dojo@aikido-hochburg-ach.at" class="contact-link">dojo@aikido-hochburg-ach.at</a>
          </div>
        </article>
      </div>
    </section>



    <section class="content-block-spacious">
      <h2 data-i18n="pages.contact.map_title">Google Maps</h2>
      <div class="map-panel">
        <div class="map-copy" data-i18n-html="pages.contact.map_copy">
          <h3>Mehrzweckhalle der neuen Mittelschule</h3>
          <p>Die Halle liegt in Duttendorf in der Gemeinde Hochburg-Ach. Über Google Maps kannst du die Route direkt öffnen.</p>
        </div>
        <div class="map-frame">
          <iframe
            src={googleMapsEmbed}
            width="100%"
            height="360"
            style="border:0;"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Google Maps Standort">
          </iframe>
          <a href={googleMapsLink} target="_blank" rel="noopener noreferrer" class="button button-primary" data-i18n="pages.contact.map_button">In Google Maps öffnen</a>
        </div>
      </div>
    </section>

    <section class="content-block-spacious closing-panel" data-i18n-html="pages.contact.closing">
      <h2>Schreib uns</h2>
      <p>Für Fragen zum Training, zu Terminen oder zum Probetraining erreichst du uns direkt per E-Mail.</p>
      <p><a href="mailto:dojo@aikido-hochburg-ach.at" class="button button-primary">dojo@aikido-hochburg-ach.at</a></p>
    </section>
  </div>
</BaseLayout>

<style>
.contact-shell {
  display: grid;
  gap: 2rem;
}

.page-header {
  padding: 3rem 2rem 0;
  text-align: center;
}

.page-header .lead {
  max-width: 44rem;
  margin: 0 auto;
  font-size: 1.15rem;
  color: var(--color-text-secondary);
}

.contact-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 1.25rem;
}

.contact-card,
.schedule-panel,
.map-panel,
.closing-panel {
  background: var(--color-surface);
  border: 1px solid var(--color-border-light);
  box-shadow: var(--shadow-sm);
}

.contact-card {
  padding: 1.5rem;
  border-radius: 24px;
  text-align: center;
}

.contact-card h3 {
  margin-top: 0;
}

.contact-card p {
  margin-bottom: 0.6rem;
}

.contact-link {
  display: block;
  margin-top: 0.45rem;
  font-weight: 700;
}

.contact-icon {
  display: grid;
  place-items: center;
  width: 3.5rem;
  height: 3.5rem;
  margin: 0 auto 1rem;
  border-radius: 50%;
  background: rgba(23, 61, 53, 0.08);
  font-size: 1.6rem;
}

.contact-note {
  color: var(--color-text-muted);
}

.schedule-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 1.25rem;
  align-items: start;
}

.schedule-panel {
  padding: 1.5rem;
  border-radius: 24px;
}

.schedule-panel h3 {
  text-align: center;
}

.map-panel {
  display: grid;
  grid-template-columns: 0.9fr 1.1fr;
  gap: 1.5rem;
  padding: 1.5rem;
  border-radius: 28px;
}

.map-copy h3 {
  margin-top: 0;
}

.map-frame {
  display: grid;
  gap: 1rem;
}

.map-frame iframe {
  border-radius: 24px;
  box-shadow: var(--shadow-sm);
}

.closing-panel {
  text-align: center;
}

@media (max-width: 960px) {
  .contact-grid,
  .schedule-grid,
  .map-panel {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 768px) {
  .page-header {
    padding-left: 0.5rem;
    padding-right: 0.5rem;
  }
}
</style>
