---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

type NewsPageProps = {
  entry: CollectionEntry<'news'>;
};

export async function getStaticPaths() {
  const entries = await getCollection('news');

  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props as NewsPageProps;
const { Content } = await entry.render();
const baseUrl = import.meta.env.BASE_URL || '/';
---

<BaseLayout title={entry.data.title} description={entry.data.preview}>
  <article class="content-block-spacious news-article">
    <p class="news-back">
      <a href={`${baseUrl}news`} class="button button-outline" data-i18n="news.back_to_overview">Zur Übersicht</a>
    </p>
    <span class="event-date">{new Date(entry.data.date).toLocaleDateString('de-DE', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
    <h1>{entry.data.title}</h1>
    {entry.data.preview && <p class="lead-text">{entry.data.preview}</p>}
    <div class="news-article-content">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
.news-article {
  max-width: 900px;
}

.news-back {
  margin-bottom: 1.5rem;
}

.news-article .event-date {
  margin-bottom: 1rem;
}

.news-article-content {
  margin-top: 2rem;
}
</style>
